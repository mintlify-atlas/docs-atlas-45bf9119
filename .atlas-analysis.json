  "keyFeatures": [
    "Embeddable Java library — integrates into any existing Java application or server",
    "Full AS4/EBMS 3.0 client and server implementation",
    "Built-in Peppol AS4 profile with SMP-based dynamic discovery",
    "Built-in CEF eDelivery profile for EU e-procurement",
    "Built-in BDEW profile for energy sector message exchange",
    "Built-in ENTSOG profile for gas transmission operators",
    "Support for DBNAlliance, EU CTP, HR eDelivery, and eDelivery2 profiles",
    "WS-Security (WSS4J) based signing and encryption",
    "Configurable PMode (Processing Mode) management",
    "Servlet and Spring Boot integration support",
    "Dynamic endpoint discovery via SMP/SML",
    "Retry mechanism for failed message deliveries",
    "Duplicate message detection",
    "MIME and MTOM attachment handling with optional compression"
  ],
  "publicApiSurface": [
    "AS4Sender.builderUserMessage()",
    "AS4Sender.builderPullRequest()",
    "AS4Servlet (Jakarta Servlet for receiving AS4 messages)",
    "AS4XServletHandler (low-level servlet handler)",
    "AS4Configuration (central configuration class)",
    "AS4CryptoFactoryConfiguration (crypto config from properties)",
    "AS4CryptoFactoryInMemoryKeyStore (programmatic crypto config)",
    "Phase4PeppolSender (Peppol-specific sending)",
    "Phase4CEFSender (CEF-specific sending)",
    "Phase4BDEWSender (BDEW-specific sending)",
    "IPhase4PeppolIncomingSBDHandlerSPI (SPI for handling incoming Peppol messages)",
    "Phase4PeppolDefaultReceiverConfiguration",
    "IAS4IncomingMessageMetadata",
    "IAS4UserMessageConsumer",
    "IAS4SignalMessageConsumer",
    "PMode / IPMode (Processing Mode model)",
    "PModeManagerInMemory / PModeManagerXML",
    "AS4IncomingHandler (low-level incoming message handler)",
    "AS4ServerInitializer (server setup helper)",
    "MetaAS4Manager (central manager registry)",
    "EAS4CompressionMode (attachment compression enum)",
    "ECryptoAlgorithmCrypt / ECryptoAlgorithmSign (crypto algorithm enums)",
    "AS4EndpointDetailProviderPeppol (dynamic discovery for Peppol)",
    "AS4EndpointDetailProviderBDXR / AS4EndpointDetailProviderBDXR2 (SMP discovery)"
  ]
}
